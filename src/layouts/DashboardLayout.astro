---
import BaseLayout from "./BaseLayout.astro";
import Logo from "@/components/layout/Logo.astro";
import { ThemeToggle } from "@/components/layout/ThemeToggle";
import type { SEOProps } from "@/lib/seo";
import { getActiveTool } from "@/lib/ai-tool";

interface Props extends SEOProps {}

const user = Astro.locals.user;
const pathname = Astro.url.pathname;
const activeTool = getActiveTool();

const sidebarLinks = [
  { href: "/dashboard", label: "Dashboard", icon: "layout-dashboard" },
  { href: "/dashboard/ai", label: activeTool.label, icon: "sparkles" },
  { href: "/dashboard/billing", label: "Billing", icon: "credit-card" },
  { href: "/dashboard/settings", label: "Settings", icon: "settings" },
];

function isActive(href: string): boolean {
  if (href === "/dashboard") return pathname === "/dashboard";
  return pathname.startsWith(href);
}
---

<BaseLayout {...Astro.props}>
  <div class="min-h-screen flex">
    <!-- Sidebar -->
    <aside class="hidden lg:flex lg:flex-col lg:w-64 border-r border-border bg-card">
      <div class="h-16 flex items-center px-6 border-b border-border">
        <Logo size="sm" />
      </div>

      <nav class="flex-1 p-4 space-y-1">
        {sidebarLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors",
              isActive(link.href)
                ? "bg-primary/10 text-primary"
                : "text-muted-foreground hover:bg-muted hover:text-foreground",
            ]}
          >
            <span class="w-5 h-5 flex items-center justify-center text-xs">
              {link.icon === "layout-dashboard" && (
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1" /><rect x="14" y="3" width="7" height="7" rx="1" /><rect x="3" y="14" width="7" height="7" rx="1" /><rect x="14" y="14" width="7" height="7" rx="1" /></svg>
              )}
              {link.icon === "sparkles" && (
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 3l1.912 5.813a2 2 0 001.275 1.275L21 12l-5.813 1.912a2 2 0 00-1.275 1.275L12 21l-1.912-5.813a2 2 0 00-1.275-1.275L3 12l5.813-1.912a2 2 0 001.275-1.275L12 3z" /></svg>
              )}
              {link.icon === "credit-card" && (
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" /><line x1="1" y1="10" x2="23" y2="10" /></svg>
              )}
              {link.icon === "settings" && (
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" /></svg>
              )}
            </span>
            {link.label}
          </a>
        ))}
      </nav>
    </aside>

    <!-- Main area -->
    <div class="flex-1 flex flex-col min-w-0">
      <!-- Topbar -->
      <header class="h-16 flex items-center justify-between px-4 sm:px-6 border-b border-border bg-card">
        <!-- Mobile sidebar toggle -->
        <button
          class="lg:hidden inline-flex items-center justify-center h-9 w-9 rounded-md hover:bg-muted transition-colors"
          aria-label="Toggle sidebar"
          id="dashboard-sidebar-toggle"
        >
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>

        <div class="lg:hidden">
          <Logo size="sm" />
        </div>

        <div class="hidden lg:block" />

        <div class="flex items-center gap-2">
          <ThemeToggle client:only="react" />

          {user && (
            <a href="/dashboard/settings" class="flex items-center gap-2 px-3 py-1.5 rounded-full hover:bg-muted transition-colors">
              <div class="w-7 h-7 rounded-full bg-primary text-primary-foreground flex items-center justify-center text-xs font-bold">
                {user.name?.charAt(0) || user.email.charAt(0).toUpperCase()}
              </div>
              <span class="hidden sm:inline text-sm font-medium">{user.name || user.email}</span>
            </a>
          )}
        </div>
      </header>

      <!-- Mobile sidebar overlay -->
      <div id="dashboard-mobile-sidebar" class="hidden fixed inset-0 z-40 lg:hidden">
        <div class="fixed inset-0 bg-black/50 backdrop-blur-sm" id="dashboard-sidebar-backdrop"></div>
        <aside class="fixed inset-y-0 left-0 z-50 w-64 bg-card border-r border-border shadow-xl">
          <div class="h-16 flex items-center justify-between px-6 border-b border-border">
            <Logo size="sm" />
            <button class="h-9 w-9 inline-flex items-center justify-center rounded-md hover:bg-muted" id="dashboard-sidebar-close">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          <nav class="p-4 space-y-1">
            {sidebarLinks.map((link) => (
              <a
                href={link.href}
                class:list={[
                  "flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors",
                  isActive(link.href)
                    ? "bg-primary/10 text-primary"
                    : "text-muted-foreground hover:bg-muted hover:text-foreground",
                ]}
              >
                {link.label}
              </a>
            ))}
          </nav>
        </aside>
      </div>

      <!-- Page content -->
      <main class="flex-1 p-4 sm:p-6 lg:p-8">
        <slot />
      </main>
    </div>
  </div>

  <script is:inline>
    const toggle = document.getElementById("dashboard-sidebar-toggle");
    const sidebar = document.getElementById("dashboard-mobile-sidebar");
    const backdrop = document.getElementById("dashboard-sidebar-backdrop");
    const close = document.getElementById("dashboard-sidebar-close");

    function openSidebar() { sidebar?.classList.remove("hidden"); }
    function closeSidebar() { sidebar?.classList.add("hidden"); }

    toggle?.addEventListener("click", openSidebar);
    backdrop?.addEventListener("click", closeSidebar);
    close?.addEventListener("click", closeSidebar);
  </script>
</BaseLayout>
