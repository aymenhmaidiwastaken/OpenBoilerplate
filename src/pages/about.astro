---
import MarketingLayout from "@/layouts/MarketingLayout.astro";
---

<MarketingLayout title="About" description="Learn more about OpenBoil and our mission.">
  <!-- Hero Section -->
  <section class="py-20 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">About OpenBoil</h1>
      <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
        We are building the ultimate open-source SaaS boilerplate to help developers launch their
        products faster. Our mission is to eliminate repetitive setup work so you can focus on what
        makes your product unique.
      </p>
    </div>
  </section>

  <!-- Mission Statement -->
  <section class="py-16 px-4 bg-muted/30">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-6">Our Mission</h2>
      <p class="text-lg text-muted-foreground max-w-3xl mx-auto">
        To democratize SaaS development by providing a production-ready, well-architected foundation
        that empowers solo developers and small teams to compete with larger organizations. We believe
        that great ideas should not be held back by boilerplate code.
      </p>
    </div>
  </section>

  <!-- Team Section -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">Meet the Team</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center">
          <div class="w-32 h-32 rounded-full bg-muted mx-auto mb-4 flex items-center justify-center">
            <span class="text-3xl text-muted-foreground">AK</span>
          </div>
          <h3 class="text-lg font-semibold">Alex Kim</h3>
          <p class="text-sm text-muted-foreground">Founder & Lead Developer</p>
        </div>

        <div class="text-center">
          <div class="w-32 h-32 rounded-full bg-muted mx-auto mb-4 flex items-center justify-center">
            <span class="text-3xl text-muted-foreground">SR</span>
          </div>
          <h3 class="text-lg font-semibold">Sara Rivera</h3>
          <p class="text-sm text-muted-foreground">Product Designer</p>
        </div>

        <div class="text-center">
          <div class="w-32 h-32 rounded-full bg-muted mx-auto mb-4 flex items-center justify-center">
            <span class="text-3xl text-muted-foreground">JT</span>
          </div>
          <h3 class="text-lg font-semibold">Jordan Taylor</h3>
          <p class="text-sm text-muted-foreground">Backend Engineer</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Values Section -->
  <section class="py-16 px-4 bg-muted/30">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">Our Values</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <div class="text-center p-6">
          <div class="w-12 h-12 rounded-lg bg-primary/10 text-primary mx-auto mb-4 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v8l4-4"/><path d="M12 2v8l-4-4"/><circle cx="12" cy="14" r="8"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Innovation</h3>
          <p class="text-sm text-muted-foreground">
            We stay on the cutting edge of web development, adopting modern tools and practices to
            give you the best possible foundation.
          </p>
        </div>

        <div class="text-center p-6">
          <div class="w-12 h-12 rounded-lg bg-primary/10 text-primary mx-auto mb-4 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Simplicity</h3>
          <p class="text-sm text-muted-foreground">
            Complexity is the enemy of execution. We design every component to be straightforward,
            well-documented, and easy to customize.
          </p>
        </div>

        <div class="text-center p-6">
          <div class="w-12 h-12 rounded-lg bg-primary/10 text-primary mx-auto mb-4 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">Community</h3>
          <p class="text-sm text-muted-foreground">
            Open source is at our core. We build in the open, welcome contributions, and support
            developers at every level of experience.
          </p>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
