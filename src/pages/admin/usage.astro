---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { UsageTracker } from "@/components/admin/UsageTracker";
---

<AdminLayout title="Usage Tracking">
  <div class="space-y-6">
    <div>
      <h2 class="text-2xl font-bold tracking-tight">Usage</h2>
      <p class="text-muted-foreground">Monitor AI usage across all users and types.</p>
    </div>

    <UsageTracker client:load />
  </div>
</AdminLayout>
