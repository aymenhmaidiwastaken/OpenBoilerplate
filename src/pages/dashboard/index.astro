---
import DashboardLayout from "@/layouts/DashboardLayout.astro";

const user = Astro.locals.user;
const isDemo = Astro.cookies.get("openboil-demo")?.value === "true";

// Demo mode shows realistic data
const credits = isDemo ? 4_320 : (user?.credits ?? 0);
const plan = isDemo ? "Pro" : "Free";
const usageThisMonth = isDemo ? 680 : 0;

const recentActivity = isDemo
  ? [
      { action: "Content generated", detail: "Blog post: \"10 Tips for SaaS Growth\"", credits: -5, time: "2 hours ago", icon: "text" },
      { action: "Image generated", detail: "Hero banner for landing page", credits: -10, time: "5 hours ago", icon: "image" },
      { action: "Document analyzed", detail: "Q4 2024 Financial Report.pdf", credits: -8, time: "Yesterday at 3:15 PM", icon: "doc" },
      { action: "Content generated", detail: "Marketing email: Product launch", credits: -5, time: "Yesterday at 11:30 AM", icon: "text" },
      { action: "Content generated", detail: "Product description: CloudSync Pro", credits: -5, time: "2 days ago", icon: "text" },
      { action: "Image generated", detail: "Social media post graphic", credits: -10, time: "2 days ago", icon: "image" },
    ]
  : [
      { action: "Content generated", detail: "Blog post introduction", credits: -5, time: "2 hours ago", icon: "text" },
      { action: "Image generated", detail: "Product hero banner", credits: -10, time: "5 hours ago", icon: "image" },
      { action: "Document analyzed", detail: "Q4 financial report", credits: -8, time: "1 day ago", icon: "doc" },
    ];
---

<DashboardLayout title="Dashboard">
  <div class="space-y-8">
    <!-- Welcome -->
    <div>
      <h1 class="text-3xl font-bold tracking-tight">
        Welcome back, {user?.name || "there"}
      </h1>
      <p class="text-muted-foreground">
        Here's an overview of your account and recent activity.
      </p>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <div class="rounded-xl border border-border bg-card text-card-foreground shadow p-6">
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm text-muted-foreground">Credits Remaining</p>
          <svg class="w-4 h-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>
        </div>
        <p class="text-3xl font-bold">{credits.toLocaleString()}</p>
        {isDemo && <p class="text-xs text-muted-foreground mt-1">of 5,000 monthly credits</p>}
      </div>

      <div class="rounded-xl border border-border bg-card text-card-foreground shadow p-6">
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm text-muted-foreground">Current Plan</p>
          <svg class="w-4 h-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2" /><line x1="1" y1="10" x2="23" y2="10" /></svg>
        </div>
        <p class="text-3xl font-bold">{plan}</p>
        {isDemo && <p class="text-xs text-emerald-500 mt-1">Active &middot; Renews Apr 2</p>}
      </div>

      <div class="rounded-xl border border-border bg-card text-card-foreground shadow p-6">
        <div class="flex items-center justify-between mb-2">
          <p class="text-sm text-muted-foreground">Usage This Month</p>
          <svg class="w-4 h-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 20V10M12 20V4M6 20v-6" /></svg>
        </div>
        <p class="text-3xl font-bold">{usageThisMonth}</p>
        {isDemo && <p class="text-xs text-muted-foreground mt-1">credits used across 47 requests</p>}
      </div>
    </div>

    <!-- Quick Actions -->
    <div>
      <h2 class="text-lg font-semibold mb-4">Quick Actions</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="/ai/content" class="rounded-xl border border-border bg-card p-4 shadow-sm hover:border-primary/50 hover:shadow-md transition-all flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-violet-500/10 text-violet-500 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3l1.912 5.813a2 2 0 001.275 1.275L21 12l-5.813 1.912a2 2 0 00-1.275 1.275L12 21l-1.912-5.813a2 2 0 00-1.275-1.275L3 12l5.813-1.912a2 2 0 001.275-1.275L12 3z" /></svg>
          </div>
          <div>
            <p class="font-medium text-sm">Generate Content</p>
            <p class="text-xs text-muted-foreground">Create text with AI</p>
          </div>
        </a>

        <a href="/ai/image" class="rounded-xl border border-border bg-card p-4 shadow-sm hover:border-primary/50 hover:shadow-md transition-all flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-amber-500/10 text-amber-500 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" /><circle cx="8.5" cy="8.5" r="1.5" /><path d="M21 15l-5-5L5 21" /></svg>
          </div>
          <div>
            <p class="font-medium text-sm">Generate Image</p>
            <p class="text-xs text-muted-foreground">Create images with AI</p>
          </div>
        </a>

        <a href="/ai/document" class="rounded-xl border border-border bg-card p-4 shadow-sm hover:border-primary/50 hover:shadow-md transition-all flex items-center gap-4">
          <div class="w-10 h-10 rounded-lg bg-emerald-500/10 text-emerald-500 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
          </div>
          <div>
            <p class="font-medium text-sm">Analyze Document</p>
            <p class="text-xs text-muted-foreground">Extract insights with AI</p>
          </div>
        </a>
      </div>
    </div>

    <!-- Recent Activity -->
    <div>
      <h2 class="text-lg font-semibold mb-4">Recent Activity</h2>
      <div class="rounded-xl border border-border bg-card text-card-foreground shadow">
        <div class="p-6">
          <div class="space-y-1">
            {recentActivity.map((item, i) => (
              <div class:list={["flex items-center justify-between py-3", i < recentActivity.length - 1 ? "border-b border-border" : ""]}>
                <div class="flex items-center gap-3">
                  <div class:list={[
                    "w-8 h-8 rounded-full flex items-center justify-center text-xs font-medium",
                    item.icon === "text" ? "bg-violet-500/10 text-violet-500" :
                    item.icon === "image" ? "bg-amber-500/10 text-amber-500" :
                    "bg-emerald-500/10 text-emerald-500"
                  ]}>
                    {item.icon === "text" ? "Aa" : item.icon === "image" ? "Img" : "Doc"}
                  </div>
                  <div>
                    <p class="text-sm font-medium">{item.action}</p>
                    <p class="text-xs text-muted-foreground">{item.detail}</p>
                  </div>
                </div>
                <div class="text-right">
                  <p class="text-sm font-medium">{item.credits} credits</p>
                  <p class="text-xs text-muted-foreground">{item.time}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
