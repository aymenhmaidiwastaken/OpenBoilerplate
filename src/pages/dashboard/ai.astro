---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import ContentGenerator from "@/components/ai/ContentGenerator";
import ImageGenerator from "@/components/ai/ImageGenerator";
import DocumentAnalyzer from "@/components/ai/DocumentAnalyzer";
import { getActiveTool, type AIToolType } from "@/lib/ai-tool";

const aitoolParam = Astro.url.searchParams.get("aitool") as AIToolType | null;
const tool = getActiveTool(aitoolParam || undefined);
---

<DashboardLayout title={tool.label}>
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">{tool.label}</h1>
      <p class="text-muted-foreground">{tool.description}</p>
    </div>

    {tool.type === "content" && <ContentGenerator client:load />}
    {tool.type === "image" && <ImageGenerator client:load />}
    {tool.type === "document" && <DocumentAnalyzer client:load />}

    <!-- Credits info -->
    <div class="rounded-lg border border-border bg-muted/30 p-4 flex items-center justify-between">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 rounded-full bg-primary/10 flex items-center justify-center">
          <svg class="w-4 h-4 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium">AI Credits</p>
          <p class="text-xs text-muted-foreground">Each AI action consumes credits based on complexity</p>
        </div>
      </div>
      <a href="/dashboard/billing" class="text-sm font-medium text-primary hover:underline">
        Manage credits &rarr;
      </a>
    </div>
  </div>
</DashboardLayout>
