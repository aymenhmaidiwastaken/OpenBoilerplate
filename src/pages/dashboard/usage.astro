---
import DashboardLayout from "@/layouts/DashboardLayout.astro";
import UsageHistory from "@/components/dashboard/UsageHistory";
---

<DashboardLayout title="Usage History">
  <div class="space-y-6">
    <div>
      <h1 class="text-3xl font-bold tracking-tight">Usage History</h1>
      <p class="text-muted-foreground">
        Track your AI usage over time and see a breakdown of credit consumption.
      </p>
    </div>

    <UsageHistory client:load />
  </div>
</DashboardLayout>
