---
// Floating side button to switch homepage designs and AI tools live
---

<div id="homepage-switcher" class="fixed right-0 top-1/2 -translate-y-1/2 z-50 flex items-center">
  <!-- Toggle tab -->
  <button
    id="switcher-toggle"
    class="flex items-center justify-center w-10 h-10 rounded-l-lg bg-primary text-primary-foreground shadow-lg hover:bg-primary/90 transition-all"
    aria-label="Switch homepage design"
  >
    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
    </svg>
  </button>

  <!-- Panel -->
  <div id="switcher-panel" class="hidden w-72 bg-card border border-border rounded-l-xl shadow-2xl overflow-hidden max-h-[90vh] overflow-y-auto">
    <div class="p-4 border-b border-border bg-muted/50">
      <div class="flex items-center justify-between">
        <h3 class="text-sm font-semibold">Template Switcher</h3>
        <button id="switcher-close" class="h-6 w-6 flex items-center justify-center rounded hover:bg-muted">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <p class="text-xs text-muted-foreground mt-1">Switch homepage design and AI tool in real-time</p>
    </div>

    <!-- Homepage Section -->
    <div class="p-3 space-y-2">
      <div class="px-1 mb-2">
        <span class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">Homepage</span>
      </div>

      <button data-homepage="modern" class="switcher-option w-full flex items-start gap-3 p-3 rounded-lg border border-border hover:border-primary/50 hover:bg-primary/5 transition-all text-left">
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-indigo-500 to-purple-500 flex-shrink-0 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
        </div>
        <div>
          <div class="text-sm font-medium">Modern SaaS</div>
          <div class="text-xs text-muted-foreground">Gradient hero, code preview, social proof</div>
        </div>
      </button>

      <button data-homepage="minimal" class="switcher-option w-full flex items-start gap-3 p-3 rounded-lg border border-border hover:border-primary/50 hover:bg-primary/5 transition-all text-left">
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-stone-400 to-stone-600 flex-shrink-0 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h8m-8 6h16" /></svg>
        </div>
        <div>
          <div class="text-sm font-medium">Minimal</div>
          <div class="text-xs text-muted-foreground">Clean editorial, generous whitespace</div>
        </div>
      </button>

      <button data-homepage="bold-dark" class="switcher-option w-full flex items-start gap-3 p-3 rounded-lg border border-border hover:border-primary/50 hover:bg-primary/5 transition-all text-left">
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-cyan-500 to-emerald-500 flex-shrink-0 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>
        </div>
        <div>
          <div class="text-sm font-medium">Bold Dark</div>
          <div class="text-xs text-muted-foreground">Neon accents, bento grid, glow effects</div>
        </div>
      </button>
    </div>

    <!-- AI Tool Section -->
    <div class="p-3 border-t border-border space-y-2">
      <div class="px-1 mb-2">
        <span class="text-xs font-semibold text-muted-foreground uppercase tracking-wider">AI Tool</span>
      </div>

      <button data-aitool="content" class="aitool-option w-full flex items-start gap-3 p-3 rounded-lg border border-border hover:border-primary/50 hover:bg-primary/5 transition-all text-left">
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-violet-500 to-purple-500 flex-shrink-0 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
        </div>
        <div>
          <div class="text-sm font-medium">Content Generator</div>
          <div class="text-xs text-muted-foreground">Blog posts, marketing copy, descriptions</div>
        </div>
      </button>

      <button data-aitool="image" class="aitool-option w-full flex items-start gap-3 p-3 rounded-lg border border-border hover:border-primary/50 hover:bg-primary/5 transition-all text-left">
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-amber-500 to-orange-500 flex-shrink-0 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909M3.75 21h16.5a2.25 2.25 0 002.25-2.25V5.25a2.25 2.25 0 00-2.25-2.25H3.75a2.25 2.25 0 00-2.25 2.25v13.5a2.25 2.25 0 002.25 2.25z" /></svg>
        </div>
        <div>
          <div class="text-sm font-medium">Image Generator</div>
          <div class="text-xs text-muted-foreground">Text-to-image, multiple styles and sizes</div>
        </div>
      </button>

      <button data-aitool="document" class="aitool-option w-full flex items-start gap-3 p-3 rounded-lg border border-border hover:border-primary/50 hover:bg-primary/5 transition-all text-left">
        <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-emerald-500 to-teal-500 flex-shrink-0 flex items-center justify-center">
          <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z" /></svg>
        </div>
        <div>
          <div class="text-sm font-medium">Document Analyzer</div>
          <div class="text-xs text-muted-foreground">Summarize, extract, and query documents</div>
        </div>
      </button>
    </div>

    <!-- Demo mode -->
    <div class="p-3 border-t border-border">
      <div class="flex items-center gap-2 p-2 rounded-lg bg-muted/50">
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" id="demo-mode-toggle" class="sr-only peer" />
          <div class="w-9 h-5 bg-muted-foreground/30 peer-checked:bg-primary rounded-full after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-full"></div>
        </label>
        <div>
          <div class="text-xs font-medium">Demo Mode</div>
          <div class="text-[10px] text-muted-foreground">Browse all pages without auth</div>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  const toggle = document.getElementById('switcher-toggle');
  const panel = document.getElementById('switcher-panel');
  const close = document.getElementById('switcher-close');
  const homepageOptions = document.querySelectorAll('.switcher-option');
  const aitoolOptions = document.querySelectorAll('.aitool-option');
  const demoToggle = document.getElementById('demo-mode-toggle');

  // Get current values from URL params
  const params = new URLSearchParams(window.location.search);
  const currentHomepage = params.get('homepage') || document.body.dataset.homepage || 'modern';
  const currentAitool = params.get('aitool') || document.body.dataset.aitool || 'content';

  // Highlight current homepage
  homepageOptions.forEach(btn => {
    if (btn.dataset.homepage === currentHomepage) {
      btn.classList.add('border-primary', 'bg-primary/5');
      btn.querySelector('.text-sm').textContent += ' \u2713';
    }
  });

  // Highlight current AI tool
  aitoolOptions.forEach(btn => {
    if (btn.dataset.aitool === currentAitool) {
      btn.classList.add('border-primary', 'bg-primary/5');
      btn.querySelector('.text-sm').textContent += ' \u2713';
    }
  });

  // Demo mode state
  const demoEnabled = localStorage.getItem('openboil-demo') === 'true';
  if (demoToggle) demoToggle.checked = demoEnabled;

  // Toggle panel
  toggle.addEventListener('click', () => {
    panel.classList.toggle('hidden');
    toggle.classList.toggle('hidden');
  });

  close.addEventListener('click', () => {
    panel.classList.add('hidden');
    toggle.classList.remove('hidden');
  });

  // Switch homepage
  homepageOptions.forEach(btn => {
    btn.addEventListener('click', () => {
      const hp = btn.dataset.homepage;
      const url = new URL(window.location.href);
      url.searchParams.set('homepage', hp);
      window.location.href = url.toString();
    });
  });

  // Switch AI tool
  aitoolOptions.forEach(btn => {
    btn.addEventListener('click', () => {
      const tool = btn.dataset.aitool;
      const url = new URL(window.location.href);
      url.searchParams.set('aitool', tool);
      // Navigate to AI dashboard to see the tool preview
      if (!url.pathname.startsWith('/dashboard/ai')) {
        url.pathname = '/dashboard/ai';
      }
      window.location.href = url.toString();
    });
  });

  // Demo mode toggle
  demoToggle?.addEventListener('change', () => {
    localStorage.setItem('openboil-demo', demoToggle.checked);
    document.cookie = demoToggle.checked
      ? 'openboil-demo=true;path=/;max-age=86400'
      : 'openboil-demo=;path=/;max-age=0';
    window.location.reload();
  });
})();
</script>
