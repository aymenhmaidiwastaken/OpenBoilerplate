---

<section class="py-24 sm:py-32">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-sm font-semibold text-primary uppercase tracking-wider mb-3">Everything you need</p>
      <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">
        Built for modern SaaS
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        Stop rebuilding the same infrastructure. Focus on what makes your product unique.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div class="group relative rounded-xl border border-border bg-card p-6 hover:border-primary/30 transition-all duration-300 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-0.5">
          <div class={`inline-flex items-center justify-center w-10 h-10 rounded-lg bg-gradient-to-br ${feature.color} text-white mb-4`}>
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-lg font-semibold mb-2">{feature.title}</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
