---
const stats = [
  { label: "GitHub Stars", value: "2.4K+", icon: "star" },
  { label: "Developers", value: "5,000+", icon: "users" },
  { label: "Components", value: "180+", icon: "layers" },
  { label: "Uptime", value: "99.9%", icon: "check" },
];
---

<section class="py-16 border-y border-border bg-muted/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
      {stats.map((stat) => (
        <div class="text-center">
          <div class="text-3xl sm:text-4xl font-bold tracking-tight bg-gradient-to-r from-foreground to-foreground/70 bg-clip-text text-transparent">
            {stat.value}
          </div>
          <div class="mt-1 text-sm text-muted-foreground">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
