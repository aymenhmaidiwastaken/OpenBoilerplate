---
import { config } from "@/config";
---

<section class="relative overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-transparent"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[800px] h-[600px] bg-primary/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-violet-500/10 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-24 sm:pt-32 sm:pb-32">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-border bg-background/50 backdrop-blur-sm text-sm text-muted-foreground mb-8">
        <span class="inline-block w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        Open Source SaaS Boilerplate
      </div>

      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-[1.1]">
        Ship your SaaS
        <span class="block bg-gradient-to-r from-primary via-violet-500 to-fuchsia-500 bg-clip-text text-transparent">
          in record time
        </span>
      </h1>

      <p class="mt-6 text-lg sm:text-xl text-muted-foreground max-w-2xl mx-auto leading-relaxed">
        Production-ready boilerplate with authentication, payments, AI integrations,
        and admin dashboard. Swap providers with a single config change.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/auth/register" class="inline-flex items-center justify-center h-12 px-8 text-base font-semibold rounded-lg bg-primary text-primary-foreground hover:bg-primary/90 transition-all shadow-lg shadow-primary/25 hover:shadow-xl hover:shadow-primary/30 hover:-translate-y-0.5">
          Get Started Free
          <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" /></svg>
        </a>
        <a href="https://github.com" class="inline-flex items-center justify-center h-12 px-8 text-base font-semibold rounded-lg border border-border bg-background hover:bg-muted transition-all">
          <svg class="mr-2 w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Star on GitHub
        </a>
      </div>

      <div class="mt-14 flex flex-col sm:flex-row items-center justify-center gap-6 text-sm text-muted-foreground">
        <div class="flex -space-x-2">
          {[0,1,2,3,4].map((i) => (
            <div class="w-8 h-8 rounded-full border-2 border-background bg-gradient-to-br from-primary/60 to-violet-500/60 flex items-center justify-center text-[10px] font-bold text-white">
              {String.fromCharCode(65 + i)}
            </div>
          ))}
        </div>
        <span>Trusted by <strong class="text-foreground">2,000+</strong> developers</span>
        <div class="flex items-center gap-1">
          {[0,1,2,3,4].map(() => (
            <svg class="w-4 h-4 text-amber-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          ))}
          <span class="ml-1 font-medium text-foreground">4.9</span>
        </div>
      </div>
    </div>

    <!-- Code Preview -->
    <div class="mt-20 max-w-3xl mx-auto">
      <div class="rounded-xl border border-border bg-card shadow-2xl shadow-black/5 dark:shadow-black/30 overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-3 border-b border-border bg-muted/50">
          <div class="flex gap-1.5">
            <div class="w-3 h-3 rounded-full bg-red-400/80"></div>
            <div class="w-3 h-3 rounded-full bg-amber-400/80"></div>
            <div class="w-3 h-3 rounded-full bg-emerald-400/80"></div>
          </div>
          <span class="ml-2 text-xs text-muted-foreground font-mono">openboil.config.ts</span>
        </div>
        <pre class="p-5 text-sm font-mono leading-relaxed overflow-x-auto"><code><span class="text-violet-500 dark:text-violet-400">providers</span>: &#123;
  <span class="text-emerald-600 dark:text-emerald-400">auth</span>:     <span class="text-amber-600 dark:text-amber-400">"custom"</span>,     <span class="text-muted-foreground">// firebase | supabase | custom</span>
  <span class="text-emerald-600 dark:text-emerald-400">payment</span>:  <span class="text-amber-600 dark:text-amber-400">"stripe"</span>,     <span class="text-muted-foreground">// stripe | lemonsqueezy</span>
  <span class="text-emerald-600 dark:text-emerald-400">database</span>: <span class="text-amber-600 dark:text-amber-400">"drizzle"</span>,    <span class="text-muted-foreground">// drizzle | firestore | supabase</span>
  <span class="text-emerald-600 dark:text-emerald-400">ai</span>:       <span class="text-amber-600 dark:text-amber-400">"openai"</span>,     <span class="text-muted-foreground">// openai | anthropic | google</span>
&#125;</code></pre>
      </div>
    </div>
  </div>
</section>
