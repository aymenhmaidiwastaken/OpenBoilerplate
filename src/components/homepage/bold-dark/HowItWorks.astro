---
const steps = [
  {
    step: "01",
    title: "Clone & Install",
    description: "One command to scaffold your project with all dependencies ready.",
    terminal: "$ npx create-openboil my-saas\n\n✓ Project created\n✓ Dependencies installed\n✓ Config generated",
  },
  {
    step: "02",
    title: "Configure Stack",
    description: "Pick your auth, payment, database, and AI provider in one config file.",
    terminal: '$ cat openboil.config.ts\n\nproviders: {\n  auth: "supabase",\n  payment: "stripe",\n  ai: "openai"\n}',
  },
  {
    step: "03",
    title: "Ship to Production",
    description: "Deploy to Vercel, Netlify, or Docker. Your SaaS is live in minutes.",
    terminal: "$ npm run build && npm run deploy\n\n✓ Build successful\n✓ Deployed to production\n✓ https://my-saas.com",
  },
];
---

<section class="relative bg-gray-950 py-24 sm:py-32">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gray-800 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center mb-20">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-cyan-400">How It Works</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl lg:text-5xl">
        Zero to production in
        <span class="bg-gradient-to-r from-cyan-400 to-green-400 bg-clip-text text-transparent">three steps</span>
      </h2>
    </div>

    <div class="mx-auto max-w-5xl grid grid-cols-1 lg:grid-cols-3 gap-8">
      {steps.map((item) => (
        <div class="relative">
          <!-- Step number -->
          <div class="mb-5 flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-cyan-500/20 to-green-500/20 border border-cyan-500/20 flex items-center justify-center text-sm font-bold text-cyan-400">
              {item.step}
            </div>
            <h3 class="text-lg font-bold text-white">{item.title}</h3>
          </div>

          <p class="text-sm text-gray-400 leading-relaxed mb-5">
            {item.description}
          </p>

          <!-- Terminal mockup -->
          <div class="rounded-xl border border-gray-800/80 bg-gray-900/60 overflow-hidden">
            <div class="flex items-center gap-2 px-4 py-2.5 border-b border-gray-800/60">
              <div class="h-2.5 w-2.5 rounded-full bg-gray-700"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-gray-700"></div>
              <div class="h-2.5 w-2.5 rounded-full bg-gray-700"></div>
              <span class="ml-2 text-[10px] text-gray-600">terminal</span>
            </div>
            <pre class="p-4 text-xs font-mono leading-relaxed text-gray-400 overflow-x-auto"><code>{item.terminal}</code></pre>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
