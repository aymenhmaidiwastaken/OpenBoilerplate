---
const screens = [
  {
    title: "User Dashboard",
    description: "Usage stats, quick actions, recent activity, billing overview.",
    mockup: "dashboard",
  },
  {
    title: "Admin Panel",
    description: "User management, analytics charts, revenue tracking, settings.",
    mockup: "admin",
  },
  {
    title: "AI Tools",
    description: "Content generation with streaming, image creation, document analysis.",
    mockup: "ai",
  },
];
---

<section class="relative bg-gray-950 py-24 sm:py-32">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gray-800 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center mb-16">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-cyan-400">What's Included</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl lg:text-5xl">
        Production-ready
        <span class="bg-gradient-to-r from-cyan-400 to-green-400 bg-clip-text text-transparent">screens</span>
      </h2>
    </div>

    <div class="mx-auto max-w-6xl grid grid-cols-1 md:grid-cols-3 gap-5">
      {screens.map((screen) => (
        <div class="group rounded-xl border border-gray-800/80 bg-gray-900/40 overflow-hidden transition-all duration-300 hover:shadow-[0_0_40px_-10px_rgba(6,182,212,0.15)] hover:border-gray-700/80">
          <!-- Screen mockup -->
          <div class="aspect-[4/3] bg-gray-900/80 border-b border-gray-800/60 relative overflow-hidden p-3">
            <div class="absolute inset-3 rounded-lg border border-gray-800/50 bg-gray-950 overflow-hidden">
              {/* Top bar */}
              <div class="h-5 border-b border-gray-800/50 bg-gray-900/50 flex items-center px-2 gap-1">
                <div class="w-1.5 h-1.5 rounded-full bg-gray-700"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-gray-700"></div>
                <div class="w-1.5 h-1.5 rounded-full bg-gray-700"></div>
              </div>
              <div class="flex h-[calc(100%-1.25rem)]">
                {/* Sidebar */}
                <div class="w-1/4 border-r border-gray-800/50 bg-gray-900/30 p-2 space-y-1.5">
                  <div class="w-full h-2 rounded bg-cyan-500/20"></div>
                  <div class="w-3/4 h-2 rounded bg-gray-800/50"></div>
                  <div class="w-full h-2 rounded bg-gray-800/50"></div>
                  <div class="w-2/3 h-2 rounded bg-gray-800/50"></div>
                </div>
                {/* Content */}
                <div class="flex-1 p-2.5 space-y-2">
                  {screen.mockup === "dashboard" && (
                    <>
                      <div class="grid grid-cols-3 gap-1.5">
                        <div class="h-7 rounded bg-cyan-500/10 border border-cyan-500/20"></div>
                        <div class="h-7 rounded bg-green-500/10 border border-green-500/20"></div>
                        <div class="h-7 rounded bg-amber-500/10 border border-amber-500/20"></div>
                      </div>
                      <div class="h-14 rounded bg-gray-800/30 border border-gray-800/40"></div>
                      <div class="h-5 rounded bg-gray-800/20"></div>
                    </>
                  )}
                  {screen.mockup === "admin" && (
                    <>
                      <div class="grid grid-cols-4 gap-1">
                        <div class="h-5 rounded bg-cyan-500/10"></div>
                        <div class="h-5 rounded bg-rose-500/10"></div>
                        <div class="h-5 rounded bg-green-500/10"></div>
                        <div class="h-5 rounded bg-amber-500/10"></div>
                      </div>
                      <div class="h-18 rounded bg-gray-800/30 border border-gray-800/40"></div>
                    </>
                  )}
                  {screen.mockup === "ai" && (
                    <>
                      <div class="h-3 rounded bg-gray-800/40 w-2/3"></div>
                      <div class="h-12 rounded bg-gradient-to-r from-cyan-500/10 to-green-500/10 border border-cyan-500/20"></div>
                      <div class="h-2.5 rounded bg-gray-800/30 w-full"></div>
                      <div class="h-2.5 rounded bg-gray-800/30 w-4/5"></div>
                    </>
                  )}
                </div>
              </div>
            </div>
          </div>

          <div class="p-5">
            <h3 class="text-sm font-bold text-white mb-1">{screen.title}</h3>
            <p class="text-xs text-gray-500">{screen.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Page tags -->
    <div class="mt-12 text-center">
      <p class="text-xs text-gray-600 mb-4 uppercase tracking-wider font-bold">Also included:</p>
      <div class="flex flex-wrap justify-center gap-2">
        {["Login & Register", "Pricing", "Blog", "Settings", "Billing", "404", "Contact", "About"].map((page) => (
          <span class="px-3 py-1 rounded-full border border-gray-800 bg-gray-900/50 text-xs font-medium text-gray-500">
            {page}
          </span>
        ))}
      </div>
    </div>
  </div>
</section>
