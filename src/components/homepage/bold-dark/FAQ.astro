---
const faqs = [
  {
    q: "Is this really free?",
    a: "Yes. MIT licensed, completely free and open source. No hidden costs.",
  },
  {
    q: "Can I use this for commercial projects?",
    a: "Absolutely. Build and sell as many SaaS products as you want.",
  },
  {
    q: "How do I switch providers?",
    a: 'Change one value in openboil.config.ts. Switching from Firebase to Supabase auth is literally changing "firebase" to "supabase".',
  },
  {
    q: "Do I need all providers set up to run locally?",
    a: "No. Use Demo Mode to browse all pages without real credentials. Set up providers when you're ready to go live.",
  },
  {
    q: "What about AI features? Do they cost money?",
    a: "The AI providers have their own pricing. OpenBoil includes the integration code and credit system — you bring your own API keys.",
  },
  {
    q: "Can I remove features I don't need?",
    a: "Yes. Toggle any feature off in config (blog, ai, admin, credits). Everything is modular.",
  },
];
---

<section class="relative bg-gray-950 py-24 sm:py-32">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gray-800 to-transparent"></div>

  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-cyan-400">FAQ</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl">
        Common questions
      </h2>
    </div>

    <div class="divide-y divide-gray-800/60">
      {faqs.map((faq) => (
        <details class="group py-5">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="text-sm font-medium text-gray-200 pr-8">{faq.q}</span>
            <svg class="w-4 h-4 text-gray-600 flex-shrink-0 transition-transform group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <p class="mt-3 text-sm text-gray-500 leading-relaxed pr-12">{faq.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
