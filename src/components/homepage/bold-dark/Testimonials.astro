---
const testimonials = [
  {
    quote: "OpenBoil saved us months of development time. We launched our SaaS in two weeks with all core features production-ready.",
    name: "Sarah Chen",
    role: "CTO at LaunchFast",
    initials: "SC",
  },
  {
    quote: "The provider swapping is mind-blowing. We switched from Firebase to Supabase by changing one line. No other boilerplate does this.",
    name: "Marcus Rodriguez",
    role: "Founder of DevStack",
    initials: "MR",
  },
  {
    quote: "The AI credit system and payment integration worked out of the box. We were charging customers within hours of starting.",
    name: "Emily Watson",
    role: "Lead Dev at Nexus AI",
    initials: "EW",
  },
];
---

<section class="relative bg-gray-950 py-24 sm:py-32">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gray-800 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center mb-16">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-cyan-400">Testimonials</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl lg:text-5xl">
        Trusted by builders
      </h2>
    </div>

    <div class="mx-auto max-w-6xl grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {testimonials.map((t) => (
        <div class="group relative flex flex-col overflow-hidden rounded-xl border border-gray-800/80 bg-gray-900/50 p-6 transition-all duration-300 hover:shadow-[0_0_30px_-5px_rgba(6,182,212,0.12)]">
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-cyan-500/0 via-cyan-500/50 to-green-500/0"></div>

          <div class="mb-4 flex gap-0.5">
            {[0,1,2,3,4].map(() => (
              <svg class="h-4 w-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          <blockquote class="flex-1 text-sm leading-relaxed text-gray-300">
            &ldquo;{t.quote}&rdquo;
          </blockquote>

          <div class="mt-6 flex items-center gap-3 border-t border-gray-800/60 pt-5">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-cyan-500/20 to-green-500/20 text-xs font-bold text-cyan-400 ring-1 ring-cyan-500/20">
              {t.initials}
            </div>
            <div>
              <p class="text-sm font-semibold text-white">{t.name}</p>
              <p class="text-xs text-gray-500">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
