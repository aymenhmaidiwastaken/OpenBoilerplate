---
---

<section class="relative overflow-hidden bg-gray-950 py-28 sm:py-36">
  <div class="absolute inset-0">
    <div class="absolute left-1/2 top-1/2 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-cyan-500/[0.07] blur-[100px]"></div>
    <div class="absolute left-1/3 top-1/2 h-64 w-64 -translate-x-1/2 -translate-y-1/2 rounded-full bg-green-500/[0.05] blur-[80px]"></div>
  </div>
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gray-800 to-transparent"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-4xl font-black uppercase tracking-tight sm:text-5xl lg:text-6xl">
        <span class="bg-gradient-to-r from-cyan-400 via-cyan-300 to-green-400 bg-clip-text text-transparent">
          Ready to ship?
        </span>
      </h2>

      <p class="mx-auto mt-5 max-w-lg text-base text-gray-400 sm:text-lg">
        Stop rebuilding the same boilerplate. Start building what makes your product unique.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/auth/register" class="group relative inline-flex h-12 items-center justify-center overflow-hidden rounded-lg px-10 text-sm font-bold uppercase tracking-wide text-white transition-transform duration-200 hover:scale-[1.03] active:scale-[0.98]">
          <span class="absolute inset-0 bg-gradient-to-r from-cyan-500 to-green-500"></span>
          <span class="absolute inset-0 bg-gradient-to-r from-cyan-400 to-green-400 opacity-0 transition-opacity duration-300 group-hover:opacity-100"></span>
          <span class="absolute -inset-1.5 rounded-xl bg-gradient-to-r from-cyan-500 to-green-500 opacity-20 blur-lg transition-opacity duration-300 group-hover:opacity-40"></span>
          <span class="relative">Get Started Free</span>
        </a>
        <a href="/docs" class="inline-flex h-12 items-center justify-center rounded-lg border border-gray-700/80 px-8 text-sm font-semibold text-gray-300 transition-all hover:border-gray-500 hover:text-white">
          Read the Docs
        </a>
      </div>

      <!-- Terminal -->
      <div class="mx-auto mt-10 max-w-md">
        <div class="overflow-hidden rounded-lg border border-gray-800/80 bg-gray-900/60">
          <div class="flex items-center gap-2 px-4 py-2.5">
            <span class="select-none text-green-400/70">$</span>
            <code class="flex-1 text-sm text-gray-300">npx create-openboil my-app</code>
          </div>
        </div>
        <p class="mt-4 text-xs text-gray-600">Free forever. No credit card required.</p>
      </div>
    </div>
  </div>
</section>
