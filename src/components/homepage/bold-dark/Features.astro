---
const features = [
  {
    title: "Provider Swapping",
    description: "Switch between auth, payments, and database providers with a single config change. Zero lock-in, zero rewrites.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" /></svg>`,
    span: "sm:col-span-2 lg:col-span-1 lg:row-span-2",
    tall: true,
  },
  {
    title: "AI-Powered",
    description: "Text generation with streaming, image creation, and document analysis. OpenAI, Anthropic, or Google.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>`,
    span: "lg:col-span-1",
    tall: false,
  },
  {
    title: "Authentication",
    description: "Firebase, Supabase, or custom JWT. Social login, magic links, role-based access — all pre-built.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" /></svg>`,
    span: "lg:col-span-1",
    tall: false,
  },
  {
    title: "Payments Ready",
    description: "Stripe and LemonSqueezy with subscriptions, billing portals, webhooks, and invoicing out of the box.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" /></svg>`,
    span: "sm:col-span-2 lg:col-span-2",
    tall: false,
  },
  {
    title: "Blog System",
    description: "MDX blog with categories, SEO optimization, and content collections. Write in Markdown, publish anywhere.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 7.5h1.5m-1.5 3h1.5m-7.5 3h7.5m-7.5 3h7.5m3-9h3.375c.621 0 1.125.504 1.125 1.125V18a2.25 2.25 0 01-2.25 2.25M16.5 7.5V4.875c0-.621-.504-1.125-1.125-1.125H4.125C3.504 3.75 3 4.254 3 4.875V18a2.25 2.25 0 002.25 2.25h13.5" /></svg>`,
    span: "lg:col-span-1",
    tall: false,
  },
  {
    title: "Admin Dashboard",
    description: "User management, analytics, revenue charts, subscription tracking, and system settings.",
    icon: `<svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>`,
    span: "lg:col-span-1",
    tall: false,
  },
];
---

<section class="relative bg-gray-950 py-24 sm:py-32">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-gray-800 to-transparent"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl text-center mb-16">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-cyan-400">Features</p>
      <h2 class="mt-3 text-3xl font-black tracking-tight text-white sm:text-4xl lg:text-5xl">
        Everything you need to
        <span class="bg-gradient-to-r from-cyan-400 to-green-400 bg-clip-text text-transparent">dominate</span>
      </h2>
    </div>

    <div class="mx-auto max-w-6xl grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3 lg:grid-rows-[auto_auto]">
      {features.map((feature) => (
        <div
          class:list={[
            "group relative overflow-hidden rounded-xl border border-gray-800/80 bg-gray-900/60 p-6 transition-all duration-300 hover:shadow-[0_0_30px_-5px_rgba(6,182,212,0.15)]",
            feature.span,
          ]}
        >
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-cyan-500/0 via-cyan-500/40 to-green-500/0 transition-opacity duration-300 group-hover:opacity-100"></div>
          <div class="absolute inset-0 bg-gradient-to-br from-cyan-500/[0.03] to-green-500/[0.03] opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>

          <div class="relative">
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg border border-gray-800 bg-gray-800/50 text-cyan-400 transition-colors duration-300 group-hover:border-cyan-500/30 group-hover:bg-cyan-500/10">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="text-base font-bold text-white">{feature.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-gray-400">{feature.description}</p>

            {feature.tall && (
              <div class="mt-6 hidden rounded-lg border border-gray-800/50 bg-gray-950/50 p-3 lg:block">
                <pre class="text-xs leading-relaxed"><code><span class="text-gray-500">// Swap in seconds</span>
<span class="text-cyan-300">auth</span>: <span class="text-green-400">"supabase"</span>  <span class="text-gray-600">&rarr;</span> <span class="text-green-400">"firebase"</span>
<span class="text-cyan-300">pay</span>:  <span class="text-green-400">"stripe"</span>    <span class="text-gray-600">&rarr;</span> <span class="text-green-400">"lemonsqueezy"</span>
<span class="text-cyan-300">ai</span>:   <span class="text-green-400">"openai"</span>    <span class="text-gray-600">&rarr;</span> <span class="text-green-400">"anthropic"</span></code></pre>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
