---
const testimonials = [
  {
    quote: "OpenBoil saved us weeks of development time. The provider system is genius — we started with Stripe and Supabase, then switched to LemonSqueezy without touching a single component.",
    name: "Sarah Chen",
    role: "CTO at LaunchFast",
    initials: "SC",
  },
  {
    quote: "The best boilerplate I've used. Clean architecture, proper TypeScript, and the AI features were a huge bonus. Launched our MVP in 3 days.",
    name: "Marcus Rodriguez",
    role: "Indie Hacker",
    initials: "MR",
  },
  {
    quote: "We evaluated 10+ boilerplates before settling on OpenBoil. The admin dashboard alone is worth it — analytics, user management, everything pre-built and production-ready.",
    name: "Emily Park",
    role: "Founder at DataPulse",
    initials: "EP",
  },
];
---

<section class="py-24 sm:py-32 bg-muted/30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl mb-16">
      <p class="text-sm font-medium text-primary mb-3">Testimonials</p>
      <h2 class="text-3xl sm:text-4xl font-semibold tracking-tight">
        Loved by developers
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="rounded-xl border border-border bg-card p-6">
          <div class="flex items-center gap-0.5 mb-4">
            {[0,1,2,3,4].map(() => (
              <svg class="w-4 h-4 text-amber-400 fill-current" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <blockquote class="text-sm leading-relaxed text-muted-foreground mb-6">
            "{t.quote}"
          </blockquote>
          <div class="flex items-center gap-3 pt-4 border-t border-border">
            <div class="w-9 h-9 rounded-full bg-primary/10 flex items-center justify-center text-xs font-bold text-primary">
              {t.initials}
            </div>
            <div>
              <div class="text-sm font-medium">{t.name}</div>
              <div class="text-xs text-muted-foreground">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
