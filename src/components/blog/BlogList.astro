---
import BlogCard from "./BlogCard.astro";

interface Props {
  posts: {
    id: string;
    data: {
      title: string;
      description: string;
      pubDate: Date;
      category: string;
      image?: string;
    };
  }[];
}

const { posts } = Astro.props;
---

{posts.length > 0 ? (
  <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
    {posts.map((post) => (
      <BlogCard post={post} />
    ))}
  </div>
) : (
  <div class="py-16 text-center">
    <p class="text-muted-foreground">No posts found.</p>
  </div>
)}
